{
	"$schema": "vscode://schemas/color-theme",
	"type": "dark",
	"colors": {
		// activity bar
		"activityBarBadge.background": "#6096A9",
		"activityBar.background": "#202020",
		"activityBar.border": "#2b2b2b",
		// main editor
		"editor.background": "#202020",
		"editor.foreground": "#dadada",
		"editor.inactiveSelectionBackground": "#3a3d41",
		"editor.selectionHighlightBackground": "#add6ff26",
		"editorBracketHighlight.foreground1": "#c0c0c0",
		"editorBracketHighlight.foreground2": "#c0c0c0",
		"editorBracketHighlight.foreground3": "#c0c0c0",
		"editorBracketHighlight.foreground4": "#c0c0c0",
		"editorBracketHighlight.foreground5": "#c0c0c0",
		"editorGroupHeader.tabsBackground": "#202020",
		"editorIndentGuide.activeBackground1": "#707070",
		"editorIndentGuide.background1": "#404040",
		"editorLineNumber.activeForeground": "#7a8286",
		"editorLineNumber.foreground": "#7a828653",
		"input.placeholderForeground": "#a6a6a6",
		"list.activeSelectionIconForeground": "#ffffff",
		"list.dropBackground": "#383b3d",
		"menu.background": "#303031",
		"menu.foreground": "#cccccc",
		"ports.iconRunningProcessForeground": "#369432",
		// inlay hints
		"editorInlayHint.background": "#ffffff00",
		"editorInlayHint.foreground": "#7a8286",
		"editorInlayHint.parameterBackground": "#ffffff00",
		"editorInlayHint.parameterForeground": "#7a8286",
		"editorInlayHint.typeBackground": "#ffffff00",
		"editorInlayHint.typeForeground": "#7a8286",
		// sidebar
		"sideBar.background": "#202020",
		"sideBar.border": "#2b2b2b",
		"sideBarSectionHeader.background": "#00000000",
		"sideBarSectionHeader.border": "#cccccc33",
		"sideBarTitle.foreground": "#bbbbbb",
		// statusbar
		"statusBar.background": "#202020",
		"statusBar.noFolderBackground": "#202020",
		"statusBarItem.remoteBackground": "#16825d",
		"statusBarItem.remoteForeground": "#ffffff",
		// tabs
		"tab.activeBackground": "#2b2b2b",
		"tab.activeBorder": "#202020",
		"tab.border": "#202020",
		"tab.inactiveBackground": "#202020",
		"tab.lastPinnedBorder": "#cccccc33",
		"terminal.inactiveSelectionBackground": "#3a3d41",
		// titlebar
		"titleBar.activeBackground": "#202020",
		"focusBorder": "#335d6c",
        "button.background": "#335d6c",
        "scrollbarSlider.background": "#7a828653",
        "list.activeSelectionBackground": "#335d6cc8",
        "list.inactiveSelectionBackground": "#5d636753",
	},
	"semanticHighlighting": true,
	"semanticTokenColors": {
		"newOperator": "#6096A9",
		"functions": "#eb6e70",
		"variables": "#c0c0c0",
		"numbers": "#82c1bd",
		"keywords": "#6096a9",
		"comments": "#7a8286",
		"strings": "#d8af64",
		"types": "#82c1bd",
		// "property": "#84b2c4",
		"property": "#d2d6a6",
		"macro": "#c0c0c0"
	},
	"tokenColors": [
		{
			"scope": "variable.other.enummember",
			"settings": {
				"foreground": "#B5CEA8"
			}
		},
		{
			"scope": "constant.character.escape",
			"settings": {
				"foreground": "#FFD68F"
			}
		},
		{
			"scope": "comment",
			"settings": {
				"foreground": "#7a8286"
			}
		},
		{
			"scope": "punctuation.definition.comment",
			"settings": {
				"foreground": "#7a8286"
			}
		},
		{
			"scope": "string",
			"settings": {
				"foreground": "#D8AF64"
			}
		},
		{
			"scope": "meta.embedded.assembly",
			"settings": {
				"foreground": "#D8AF64"
			}
		},
		{
			"scope": "keyword - keyword.operator",
			"settings": {
				"foreground": "#6096A9"
			}
		},
		{
			"scope": "keyword.control",
			"settings": {
				"foreground": "#6096A9"
			}
		},
		{
			"scope": "storage",
			"settings": {
				"foreground": "#6096A9"
			}
		},
		{
			"scope": "storage.type",
			"settings": {
				"foreground": "#6096A9"
			}
		},
		{
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#82C1BD"
			}
		},
		{
			"scope": "entity.name.type",
			"settings": {
				"foreground": "#82C1BD"
			}
		},
		{
			"scope": "entity.name.class",
			"settings": {
				"foreground": "#82C1BD"
			}
		},
		{
			"scope": "support.type",
			"settings": {
				"foreground": "#82C1BD"
			}
		},
		{
			"scope": "support.class",
			"settings": {
				"foreground": "#82C1BD"
			}
		},
		{
			"scope": "entity.name.function",
			"settings": {
				"foreground": "#EB6E70"
			}
		},
		{
			"scope": "support.function",
			"settings": {
				"foreground": "#EB6E70"
			}
		},
		{
			"scope": "variable",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "entity.name.variable",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "storage.modifier",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "variable",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "constant.language",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "keyword.other.using",
			"settings": {
				"foreground": "#6096A9"
			}
		},
		{
			"scope": "keyword.other.unit.exponent.decimal.cpp",
			"settings": {
				"foreground": "#82c1bd"
			}
		},
		{
			"scope": "string.regexp",
			"settings": {
				"foreground": "#D8AF64"
			}
		},
		{
			"scope": "variable.parameter",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "punctuation.definition.string",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "variable.other.property",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "keyword.other",
			"settings": {
				"foreground": "#6096A9"
			}
		},
		{
			"scope": "markup.bold",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "constant.character",
			"settings": {
				"foreground": "#6096A9"
			}
		},
		{
			"scope": "constant.character.math.tex",
			"settings": {
				"foreground": "#82C1BD"
			}
		},
		{
			"scope": "variable.language",
			"settings": {
				"foreground": "#6096A9"
			}
		},
		{
			"scope": "source.cpp",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "source.python",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "punctuation.definition.string.begin.tex",
			"settings": {
				"foreground": "#D8AF64"
			}
		},
		{
			"scope": "punctuation.definition.string.end.tex",
			"settings": {
				"foreground": "#D8AF64"
			}
		},
		{
			"scope": "text.tex.latex",
			"settings": {
				"foreground": "#C0C0C0"
			}
		},
		{
			"scope": "token.info-token",
			"settings": {
				"foreground": "#6796E6"
			}
		},
		{
			"scope": "token.warn-token",
			"settings": {
				"foreground": "#CD9731"
			}
		},
		{
			"scope": "token.error-token",
			"settings": {
				"foreground": "#F44747"
			}
		},
		{
			"scope": "token.debug-token",
			"settings": {
				"foreground": "#B267E6"
			}
		}
	]
}